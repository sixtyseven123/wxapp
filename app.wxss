/* 全局样式 - 人格实验室 */
page {
  --primary-color: #7B68EE;
  --primary-light: #9999FF;
  --primary-dark: #5B48AE;
  --secondary-color: #87CEEB;
  --accent-color: #DDA0DD;
  --bg-color: #F8F8FF;
  --bg-secondary: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #E8E8F0;
  --shadow-light: 0 2rpx 10rpx rgba(123, 104, 238, 0.1);
  --shadow-medium: 0 4rpx 20rpx rgba(123, 104, 238, 0.15);
  --shadow-strong: 0 8rpx 30rpx rgba(123, 104, 238, 0.2);
  --radius-small: 12rpx;
  --radius-medium: 20rpx;
  --radius-large: 32rpx;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-light);
}

/* 标题样式 */
.title-h1 {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.title-h2 {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.title-h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-large);
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  border: none;
  outline: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  box-shadow: var(--shadow-medium);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-light);
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  background: var(--primary-color);
  color: white;
}

.btn-block {
  width: 100%;
}

/* 选项按钮 */
.option-btn {
  width: 100%;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-medium);
  text-align: left;
  font-size: 30rpx;
  color: var(--text-primary);
  transition: all 0.2s ease;
}

.option-btn.selected {
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.1), rgba(153, 153, 255, 0.1));
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.option-btn:active {
  transform: scale(0.98);
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: var(--border-color);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mt-50 { margin-top: 50rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }

/* 文字 */
.text-center { text-align: center; }
.text-primary { color: var(--primary-color); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-small { font-size: 24rpx; }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 30rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 50rpx;
  color: var(--text-light);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.animate-fadeIn {
  animation: fadeIn 0.5s ease forwards;
}

.animate-scaleIn {
  animation: scaleIn 0.4s ease forwards;
}

/* 页面安全区适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
/* 结果页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F8FF 0%, #E8E8F5 100%);
}

.header-bg {
  position: relative;
  height: 500rpx;
}

.bg-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-light) 50%, #E8E8F5 100%);
  border-radius: 0 0 50% 50%;
}

/* 主内容 */
.result-content {
  position: relative;
  margin-top: -300rpx;
  padding: 0 30rpx 60rpx;
  z-index: 10;
}

/* 人格类型卡片 */
.type-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-large);
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-strong);
  text-align: center;
}

.type-main {
  margin-bottom: 40rpx;
}

.type-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.type-letter {
  font-size: 120rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
}

.type-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.type-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.type-share {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 趣味测试卡片 */
.fun-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-large);
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-strong);
  text-align: center;
}

.fun-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.fun-tag {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.fun-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.fun-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 维度卡片 */
.dimension-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.radar-container {
  width: 100%;
  height: 350rpx;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.radar-canvas {
  width: 300rpx;
  height: 300rpx;
  display: block;
}

.dimension-list {
  display: flex;
  flex-direction: column;
}

.dimension-item {
  margin-bottom: 20rpx;
}

.dimension-item:last-child {
  margin-bottom: 0;
}

.dimension-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dim-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dim-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.dimension-bar {
  height: 12rpx;
  background: var(--bg-color);
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-inner {
  height: 100%;
  border-radius: 6rpx;
  transition: width 1s ease;
}

/* 通用卡片 */
.card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 30rpx;
  text-align: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title .icon {
  margin-right: 12rpx;
}

.section-list {
  display: flex;
  flex-direction: column;
}

.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.list-item:last-child {
  margin-bottom: 0;
}

.item-bullet {
  color: var(--primary-color);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.tag {
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  margin: 10rpx;
}

/* 名人卡片 */
.celebrity-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.celebrity-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.celebrity-item {
  background: var(--bg-color);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  margin: 10rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 趣味结果卡片 */
.fun-result-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.harsh-text {
  font-size: 28rpx;
  color: #FF6B6B;
  line-height: 1.8;
  font-style: italic;
}

.suggestion-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-buttons .btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-buttons .btn text {
  margin-right: 10rpx;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn-outline:active {
  background: var(--primary-color);
  color: white;
}

/* 测试信息 */
.test-info {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
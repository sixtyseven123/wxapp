/* 历史记录页样式 */
.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  padding: 20rpx 0 30rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 筛选栏 */
.filter-bar {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.filter-row {
  margin-bottom: 20rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background: var(--bg-color);
  border-radius: var(--radius-small);
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.filter-option.active {
  background: var(--primary-color);
  color: #fff;
}

/* 历史记录列表 */
.history-list {
  margin-bottom: 40rpx;
}

.history-item {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
  overflow: hidden;
}

.history-item:active {
  transform: scale(0.98);
}

.item-left {
  flex: 1;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.item-info {
  flex: 1;
  overflow: hidden;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.item-info {
  flex: 1;
}

.item-type {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 6rpx;
}

.item-result {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.item-actions {
  display: flex;
  gap: 20rpx;
  padding: 10rpx;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-color);
  font-size: 36rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-btn:active {
  transform: scale(0.9);
  opacity: 0.7;
}

.action-btn-hover {
  background: #fff5f5;
}

.action-icon {
  font-size: 36rpx;
}

.edit-btn {
  color: var(--primary-color);
}

.delete-btn {
  color: #FF6B6B;
  background: #fff5f5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 50rpx 50rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 清除按钮 */
.clear-section {
  text-align: center;
  padding: 40rpx 0;
}

.btn-clear {
  background: transparent;
  border: none;
  color: var(--text-light);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-clear text {
  margin-right: 8rpx;
}

.btn-clear::after {
  border: none;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-large);
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-light);
  padding: 8rpx;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.form-value {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: var(--radius-small);
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: var(--radius-small);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.modal-footer .btn {
  flex: 1;
}
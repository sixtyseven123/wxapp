/* 历史记录页样式 */
.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  padding: 20rpx 0 40rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 历史记录列表 */
.history-list {
  margin-bottom: 40rpx;
}

.history-item {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.history-item:active {
  transform: scale(0.98);
}

.item-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.item-info {
  flex: 1;
}

.item-type {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 6rpx;
}

.item-result {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.item-arrow {
  font-size: 40rpx;
  color: var(--text-light);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 50rpx 50rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 清除按钮 */
.clear-section {
  text-align: center;
  padding: 40rpx 0;
}

.btn-clear {
  background: transparent;
  border: none;
  color: var(--text-light);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-clear text {
  margin-right: 8rpx;
}

.btn-clear::after {
  border: none;
}
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">测试记录</view>
    <view class="header-subtitle">共 {{history.length}} 条记录</view>
  </view>
  
  <!-- 历史记录列表 -->
  <view class="history-list" wx:if="{{history.length > 0}}">
    <view 
      class="history-item card animate-fadeIn"
      wx:for="{{history}}"
      wx:key="index"
      bindtap="viewResult"
      data-index="{{index}}"
      style="animation-delay: {{index * 0.05}}s"
    >
      <view class="item-left">
        <view class="item-icon">
          <text wx:if="{{item.type === 'fun'}}">🎭</text>
          <text wx:else>{{item.result.icon || '🧠'}}</text>
        </view>
        <view class="item-info">
          <view class="item-type">
            <text wx:if="{{item.type === 'mbti_full'}}">MBTI标准版</text>
            <text wx:elif="{{item.type === 'mbti_quick'}}">MBTI快速版</text>
            <text wx:elif="{{item.type === 'fun'}}">趣味人格测试</text>
          </view>
          <view class="item-result">
            <text wx:if="{{item.type === 'fun'}}">{{item.result.funTag}}</text>
            <text wx:else>{{item.result.type}} {{item.result.name}}</text>
          </view>
          <view class="item-time">{{item.timeStr}}</view>
        </view>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{history.length === 0}}">
    <image src="/assets/images/empty-history.png" mode="aspectFit" wx:if="{{false}}"></image>
    <view class="empty-icon">📜</view>
    <view class="empty-text">暂无测试记录</view>
    <view class="empty-hint">开始测试后，记录将显示在这里</view>
    <button class="btn btn-primary mt-40" bindtap="goToTest">开始测试</button>
  </view>
  
  <!-- 清除按钮 -->
  <view class="clear-section" wx:if="{{history.length > 0}}">
    <button class="btn-clear" bindtap="showClearConfirm">
      <text>🗑️</text> 清除所有记录
    </button>
  </view>
</view>
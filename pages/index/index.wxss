/* 首页样式 */
.header-decoration {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.15), rgba(135, 206, 235, 0.1));
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
  animation: pulse 4s ease-in-out infinite;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 50rpx;
  left: -80rpx;
  animation: pulse 5s ease-in-out infinite 0.5s;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  top: 150rpx;
  right: 100rpx;
  animation: pulse 3s ease-in-out infinite 1s;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.logo-container {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  animation: scaleIn 0.6s ease forwards;
}

.logo-text {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 测试卡片 */
.test-cards {
  padding: 0 30rpx;
}

.test-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-light);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.test-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.test-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-light);
}

.test-card:active::before {
  opacity: 1;
}

.card-primary::before {
  opacity: 1;
}

.card-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.card-info {
  flex: 1;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.card-features {
  display: flex;
  flex-wrap: wrap;
}

.card-arrow {
  font-size: 48rpx;
  color: var(--text-light);
  margin-left: 20rpx;
}

/* 底部功能入口 */
.bottom-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 50rpx 30rpx 30rpx;
  margin: 0 30rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  box-shadow: var(--shadow-light);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 广告位 */
.ad-container {
  margin: 30rpx;
  border-radius: var(--radius-medium);
  overflow: hidden;
  background: var(--bg-secondary);
}

/* 版权 */
.copyright {
  text-align: center;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: var(--text-light);
}
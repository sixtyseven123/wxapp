/* 答题页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F8FF 0%, #E8E8F5 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.header {
  padding-top: 60rpx;
  padding-bottom: 20rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
}

.header-inner {
  padding: 0 30rpx;
  display: flex;
  align-items: center;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: white;
  margin-right: 20rpx;
}

.progress-info {
  flex: 1;
}

.progress-text {
  font-size: 28rpx;
  color: white;
  margin-bottom: 10rpx;
  display: block;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: white;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.test-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 20rpx;
  white-space: nowrap;
}

/* 题目区域 */
.question-section {
  flex: 1;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
}

/* 题目卡片 */
.question-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-light);
}

.question-type-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.tag-icon {
  margin-right: 8rpx;
}

.question-text {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 选项列表 */
.options-list {
  flex: 1;
}

.option-btn {
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-medium);
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.option-btn:active {
  transform: scale(0.98);
}

.option-btn.selected {
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.08), rgba(153, 153, 255, 0.08));
  border-color: var(--primary-color);
}

.option-label {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-btn.selected .option-label {
  background: var(--primary-color);
  color: white;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.nav-buttons .btn {
  flex: 1;
}

.btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 完成页面 */
.finish-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.finish-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.finish-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.finish-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-color);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1.2); opacity: 1; }
}

/* 时间提示 */
.time-hint {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: var(--text-light);
}
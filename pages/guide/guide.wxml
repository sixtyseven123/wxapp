<view class="container">
  <!-- 顶部背景 -->
  <view class="header-bg">
    <view class="bg-decoration"></view>
  </view>
  
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text>‹</text>
  </view>
  
  <!-- 内容区域 -->
  <view class="content-section">
    <!-- 测试标题 -->
    <view class="test-header animate-fadeIn">
      <view class="test-icon">{{testIcon}}</view>
      <view class="test-title">{{testTitle}}</view>
      <view class="test-count">共{{testCount}}题</view>
    </view>
    
    <!-- 测试说明卡片 -->
    <view class="info-card card animate-fadeIn" style="animation-delay: 0.1s">
      <view class="info-title">
        <text class="icon">📋</text>
        测试说明
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="num">1</text>
          <text class="text">本测试按第一印象回答，无需深思熟虑</text>
        </view>
        <view class="info-item">
          <text class="num">2</text>
          <text class="text">每个题目没有正确或错误的答案</text>
        </view>
        <view class="info-item">
          <text class="num">3</text>
          <text class="text">请选择最接近你真实想法的选项</text>
        </view>
        <view class="info-item">
          <text class="num">4</text>
          <text class="text">保持安静环境效果更佳</text>
        </view>
      </view>
    </view>
    
    <!-- 预计时长 -->
    <view class="time-card card animate-fadeIn" style="animation-delay: 0.2s">
      <view class="time-icon">⏱️</view>
      <view class="time-info">
        <view class="time-label">预计时长</view>
        <view class="time-value">{{estimateTime}}</view>
      </view>
    </view>
    
    <!-- 隐私协议 -->
    <view class="privacy-section animate-fadeIn" style="animation-delay: 0.3s">
      <label class="privacy-checkbox" bindtap="togglePrivacy">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <text class="privacy-text">我已阅读并同意<text class="link" catchtap="showPrivacy">《隐私政策》</text>和<text class="link" catchtap="showAgreement">《用户协议》</text></text>
      </label>
    </view>
    
    <!-- 开始按钮 -->
    <view class="start-section animate-fadeIn" style="animation-delay: 0.4s">
      <button class="btn btn-primary btn-block {{!agreed ? 'disabled' : ''}}" bindtap="startTest" disabled="{{!agreed}}">
        开始测试
      </button>
      <button class="btn btn-secondary btn-block mt-20" bindtap="goBack">返回首页</button>
    </view>
  </view>
</view>